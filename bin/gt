#!/usr/bin/env bash
set -euo pipefail

GT_VERSION="1.0.0"
GT_AUTHOR="Pro Cloudify · github.com/procloudify/gt"
VERSION_FILE=".version"

# ── colors ───────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

ok()   { echo -e "${GREEN}✓${RESET} $*"; }
info() { echo -e "${CYAN}→${RESET} $*"; }
warn() { echo -e "${YELLOW}!${RESET} $*"; }
die()  { echo -e "${RED}✗${RESET} $*" >&2; exit 1; }

# ── helpers ──────────────────────────────────────────────────────────────
require_git() {
  git rev-parse --git-dir &>/dev/null || die "Not a git repository."
}

current_branch() {
  git rev-parse --abbrev-ref HEAD
}

ensure_version_file() {
  if [ ! -f "$VERSION_FILE" ]; then
    echo "1.0.0" > "$VERSION_FILE"
    ok "Created $VERSION_FILE with version 1.0.0"
  fi
}

read_version() {
  ensure_version_file
  cat "$VERSION_FILE"
}

bump_version() {
  local part="${1:-patch}"
  local ver; ver=$(read_version)
  local major minor patch
  major=$(echo "$ver" | cut -d. -f1)
  minor=$(echo "$ver" | cut -d. -f2)
  patch=$(echo "$ver" | cut -d. -f3)
  case "$part" in
    major) major=$((major+1)); minor=0; patch=0 ;;
    minor) minor=$((minor+1)); patch=0 ;;
    patch) patch=$((patch+1)) ;;
    *) die "Unknown version part '$part'. Use major, minor, or patch." ;;
  esac
  echo "$major.$minor.$patch"
}

pick_branch() {
  local branches
  branches=$(git branch -a --format='%(refname:short)' | sed 's|origin/||' | sort -u | grep -v HEAD)
  if command -v fzf &>/dev/null; then
    echo "$branches" | fzf --prompt="branch> " --height=10
  else
    echo "$branches" | nl -w2 -s') '
    printf "Pick number: "; read -r n
    echo "$branches" | sed -n "${n}p"
  fi
}

# ── parse flags ──────────────────────────────────────────────────────────
# Usage: parse_flags "$@"
# Sets: FLAG_MSG, FLAG_TYPE, REST_ARGS
parse_flags() {
  FLAG_MSG=""
  FLAG_TYPE="patch"
  REST_ARGS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--message)
        shift
        FLAG_MSG="${1:-}"
        shift
        ;;
      -m*)
        FLAG_MSG="${1#-m}"
        shift
        ;;
      major|minor|patch)
        FLAG_TYPE="$1"
        shift
        ;;
      *)
        REST_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

# ── commands ─────────────────────────────────────────────────────────────

cmd_push() {
  require_git
  parse_flags "$@"

  local new_ver; new_ver=$(bump_version "$FLAG_TYPE")
  echo "$new_ver" > "$VERSION_FILE"

  # Commit message: "1.2.3" or "1.2.3 — your message"
  local commit_msg="$new_ver"
  [ -n "$FLAG_MSG" ] && commit_msg="$new_ver — $FLAG_MSG"

  info "Version  → ${BOLD}$new_ver${RESET}"
  [ -n "$FLAG_MSG" ] && info "Message  → ${BOLD}$FLAG_MSG${RESET}"

  git checkout main 2>/dev/null || git checkout -b main
  git add .
  git commit -m "$commit_msg" --allow-empty
  git push origin main
  ok "Pushed main @ $commit_msg"
}

cmd_dev() {
  require_git
  parse_flags "$@"

  # Commit message: "dev snapshot" or custom message
  local commit_msg="${FLAG_MSG:-dev snapshot}"

  info "Message  → ${BOLD}$commit_msg${RESET}"

  git checkout dev 2>/dev/null || git checkout -b dev
  git add .
  git commit -m "$commit_msg" --allow-empty
  git push origin dev
  ok "Pushed dev: $commit_msg"
}

cmd_branch() {
  require_git
  local name="${1:-}"
  [ -z "$name" ] && { printf "Branch name: "; read -r name; }
  [ -z "$name" ] && die "Branch name required."
  git checkout -b "$name"
  git push -u origin "$name"
  ok "Created and pushed branch: ${BOLD}$name${RESET}"
}

cmd_pull() {
  require_git
  local branch="${1:-}"
  [ -z "$branch" ] && branch=$(current_branch)
  info "Pulling ${BOLD}$branch${RESET}..."
  git pull origin "$branch"
  ok "Pulled $branch"
}

cmd_switch() {
  require_git
  local branch="${1:-}"
  [ -z "$branch" ] && branch=$(pick_branch)
  [ -z "$branch" ] && die "No branch selected."
  git fetch origin "$branch" 2>/dev/null || true
  git checkout "$branch"
  ok "Switched to ${BOLD}$branch${RESET}"
}

cmd_merge() {
  require_git
  local branch="${1:-}"
  [ -z "$branch" ] && branch=$(pick_branch)
  [ -z "$branch" ] && die "No branch selected."
  local current; current=$(current_branch)
  info "Merging ${BOLD}$branch${RESET} → ${BOLD}$current${RESET}"
  git merge "$branch"
  ok "Merged $branch into $current"
}

cmd_status() {
  require_git
  local branch; branch=$(current_branch)
  local ver="n/a"
  [ -f "$VERSION_FILE" ] && ver=$(cat "$VERSION_FILE")
  echo -e "\n${BOLD}Branch:${RESET}  $branch"
  echo -e "${BOLD}Version:${RESET} $ver\n"
  git status -s | while IFS= read -r line; do
    local flag="${line:0:2}"
    case "$flag" in
      "M "|" M") echo -e "  ${YELLOW}~${RESET} ${line:3}" ;;
      "A "|" A") echo -e "  ${GREEN}+${RESET} ${line:3}" ;;
      "D "|" D") echo -e "  ${RED}-${RESET} ${line:3}" ;;
      "??")       echo -e "  ${CYAN}?${RESET} ${line:3}" ;;
      *)          echo "  $line" ;;
    esac
  done
  echo ""
}

cmd_log() {
  require_git
  local n="${1:-10}"
  echo ""
  git log --oneline -"$n" --color=always \
    --pretty=format:"%C(yellow)%h%Creset %C(cyan)%ad%Creset %s %C(dim)(%an)%Creset" \
    --date=short
  echo ""
}

cmd_version() {
  local part="${1:-patch}"
  local new_ver; new_ver=$(bump_version "$part")
  echo "$new_ver" > "$VERSION_FILE"
  ok "Version bumped → ${BOLD}$new_ver${RESET}"
}

cmd_init() {
  if git rev-parse --git-dir &>/dev/null; then
    warn "Already a git repo."
  else
    git init
    ok "Git repo initialized."
  fi
  ensure_version_file
  if [ ! -f ".gitignore" ]; then
    cat > .gitignore << 'IGNORE'
.DS_Store
node_modules/
*.log
IGNORE
    ok "Created .gitignore"
  fi
  ok "gt ready. Try: gt status"
}

cmd_help() {
  echo -e "
${BOLD}gt${RESET} — simple git flow CLI  v${GT_VERSION}  ${DIM}by Pro Cloudify${RESET}

${BOLD}USAGE${RESET}
  gt <command> [options]

${BOLD}COMMANDS${RESET}
  ${CYAN}push${RESET} [major|minor|patch] [-m \"msg\"]   bump version + commit + push main
  ${CYAN}dev${RESET}  [-m \"msg\"]                       commit + push to dev branch
  ${CYAN}branch${RESET} <name>                          create + push a new branch
  ${CYAN}switch${RESET} [name]                          switch branch (interactive if no name)
  ${CYAN}pull${RESET}  [branch]                         pull from branch (default: current)
  ${CYAN}merge${RESET} [branch]                         merge branch into current
  ${CYAN}status${RESET}                                 pretty status with version info
  ${CYAN}log${RESET}   [n]                              last n commits (default: 10)
  ${CYAN}version${RESET} [major|minor|patch]            bump .version file only
  ${CYAN}init${RESET}                                   init repo + .version + .gitignore

${BOLD}EXAMPLES${RESET}
  gt push                          → 1.0.1  (auto patch bump)
  gt push -m \"fix login bug\"       → 1.0.1 — fix login bug
  gt push minor -m \"new dashboard\" → 1.1.0 — new dashboard
  gt push major                    → 2.0.0
  gt dev                           → dev snapshot
  gt dev -m \"working on auth\"      → working on auth
  gt branch feature/login
  gt switch main
  gt merge feature/login
  gt pull
  gt log 20

${DIM}  github.com/procloudify/gt${RESET}
"
}

# ── router ───────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    push)    cmd_push    "$@" ;;
    dev)     cmd_dev     "$@" ;;
    branch)  cmd_branch  "$@" ;;
    switch)  cmd_switch  "$@" ;;
    pull)    cmd_pull    "$@" ;;
    merge)   cmd_merge   "$@" ;;
    status)  cmd_status  "$@" ;;
    log)     cmd_log     "$@" ;;
    version) cmd_version "$@" ;;
    init)    cmd_init    "$@" ;;
    help|-h|--help) cmd_help ;;
    *) die "Unknown command '$cmd'. Run: gt help" ;;
  esac
}

main "$@"
