#!/usr/bin/env bash
set -euo pipefail

GT_VERSION="1.0.0"
GT_AUTHOR="Pro Cloudify · github.com/procloudify/gt"
VERSION_FILE=".version"

# ── colors ───────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

ok()   { echo -e "${GREEN}✓${RESET} $*"; }
info() { echo -e "${CYAN}→${RESET} $*"; }
warn() { echo -e "${YELLOW}!${RESET} $*"; }
die()  { echo -e "${RED}✗${RESET} $*" >&2; exit 1; }

# ── helpers ──────────────────────────────────────────────────────────────
require_git() {
  git rev-parse --git-dir &>/dev/null || die "Not a git repository."
}

require_origin() {
  git remote get-url origin &>/dev/null || die "No remote 'origin' configured. Run: git remote add origin <url>"
}

current_branch() {
  git rev-parse --abbrev-ref HEAD
}

is_dirty() {
  ! git diff --quiet || ! git diff --cached --quiet
}

has_untracked() {
  [ -n "$(git ls-files --others --exclude-standard)" ]
}

ensure_version_file() {
  if [ ! -f "$VERSION_FILE" ]; then
    echo "1.0.0" > "$VERSION_FILE"
    ok "Created $VERSION_FILE with version 1.0.0"
  fi
}

read_version() {
  ensure_version_file
  local ver; ver=$(cat "$VERSION_FILE" | tr -d '[:space:]')
  if ! echo "$ver" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
    die "Invalid version in $VERSION_FILE: '$ver'. Expected format: X.Y.Z"
  fi
  echo "$ver"
}

bump_version() {
  local part="${1:-patch}"
  local ver; ver=$(read_version)
  local major minor patch
  major=$(echo "$ver" | cut -d. -f1)
  minor=$(echo "$ver" | cut -d. -f2)
  patch=$(echo "$ver" | cut -d. -f3)
  case "$part" in
    major) major=$((major+1)); minor=0; patch=0 ;;
    minor) minor=$((minor+1)); patch=0 ;;
    patch) patch=$((patch+1)) ;;
    *) die "Unknown version part '$part'. Use major, minor, or patch." ;;
  esac
  echo "$major.$minor.$patch"
}

pick_branch() {
  local branches
  # deduplicate: strip remote prefix, exclude HEAD, sort unique
  branches=$(git branch -a --format='%(refname:short)' \
    | sed 's|^origin/||' \
    | grep -v '^HEAD$' \
    | sort -u)
  if command -v fzf &>/dev/null; then
    echo "$branches" | fzf --prompt="branch> " --height=10
  else
    echo "$branches" | nl -w2 -s') '
    printf "Pick number: "; read -r n
    echo "$branches" | sed -n "${n}p"
  fi
}

safe_switch() {
  local target="$1"
  local current; current=$(current_branch)
  [ "$current" = "$target" ] && return 0
  if is_dirty || has_untracked; then
    warn "You have uncommitted changes. Stashing before switching to ${BOLD}$target${RESET}..."
    git stash push -u -m "gt auto-stash before switching to $target"
    git checkout "$target" 2>/dev/null || git checkout -b "$target"
    warn "Changes stashed. Run ${BOLD}git stash pop${RESET} to restore them."
  else
    git checkout "$target" 2>/dev/null || git checkout -b "$target"
  fi
}

safe_commit() {
  local msg="$1"
  git add .
  if git diff --cached --quiet; then
    warn "Nothing to commit — working tree clean. Skipping commit."
    return 1
  fi
  git commit -m "$msg"
  return 0
}

# ── parse flags ──────────────────────────────────────────────────────────
# Usage: parse_flags "$@"
# Sets: FLAG_MSG, FLAG_TYPE, REST_ARGS
parse_flags() {
  FLAG_MSG=""
  FLAG_TYPE="patch"
  REST_ARGS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--message)
        shift
        FLAG_MSG="${1:-}"
        shift
        ;;
      -m*)
        FLAG_MSG="${1#-m}"
        shift
        ;;
      major|minor|patch)
        FLAG_TYPE="$1"
        shift
        ;;
      *)
        REST_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

# ── commands ─────────────────────────────────────────────────────────────

cmd_push() {
  require_git
  require_origin
  parse_flags "$@"

  local new_ver; new_ver=$(bump_version "$FLAG_TYPE")

  local commit_msg="$new_ver"
  [ -n "$FLAG_MSG" ] && commit_msg="$new_ver — $FLAG_MSG"

  info "Version  → ${BOLD}$new_ver${RESET}"
  [ -n "$FLAG_MSG" ] && info "Message  → ${BOLD}$FLAG_MSG${RESET}"

  safe_switch main
  echo "$new_ver" > "$VERSION_FILE"
  if safe_commit "$commit_msg"; then
    git push origin main
    ok "Pushed main @ $commit_msg"
  else
    warn "Version file updated to $new_ver but nothing pushed (no changes)."
  fi
}

cmd_dev() {
  require_git
  require_origin
  parse_flags "$@"

  local commit_msg="${FLAG_MSG:-dev snapshot}"
  info "Message  → ${BOLD}$commit_msg${RESET}"

  safe_switch dev
  if safe_commit "$commit_msg"; then
    git push origin dev
    ok "Pushed dev: $commit_msg"
  fi
}

cmd_branch() {
  require_git
  local name="${1:-}"
  [ -z "$name" ] && { printf "Branch name: "; read -r name; }
  [ -z "$name" ] && die "Branch name required."
  git checkout -b "$name"
  git push -u origin "$name"
  ok "Created and pushed branch: ${BOLD}$name${RESET}"
}

cmd_pull() {
  require_git
  local branch="${1:-}"
  [ -z "$branch" ] && branch=$(current_branch)
  info "Pulling ${BOLD}$branch${RESET}..."
  git pull origin "$branch"
  ok "Pulled $branch"
}

cmd_switch() {
  require_git
  local branch="${1:-}"
  [ -z "$branch" ] && branch=$(pick_branch)
  [ -z "$branch" ] && die "No branch selected."
  git fetch origin "$branch" 2>/dev/null || true
  git checkout "$branch"
  ok "Switched to ${BOLD}$branch${RESET}"
}

cmd_merge() {
  require_git
  local branch="${1:-}"
  [ -z "$branch" ] && branch=$(pick_branch)
  [ -z "$branch" ] && die "No branch selected."
  local current; current=$(current_branch)
  [ "$branch" = "$current" ] && die "Already on '$branch' — nothing to merge."
  if is_dirty; then
    die "Uncommitted changes detected. Commit or stash them before merging."
  fi
  info "Merging ${BOLD}$branch${RESET} → ${BOLD}$current${RESET}"
  git merge --no-ff "$branch" || die "Merge conflict. Resolve conflicts then run: git merge --continue"
  ok "Merged $branch into $current"
}

cmd_status() {
  require_git
  local branch; branch=$(current_branch)
  local ver="n/a"
  [ -f "$VERSION_FILE" ] && ver=$(cat "$VERSION_FILE")
  echo -e "\n${BOLD}Branch:${RESET}  $branch"
  echo -e "${BOLD}Version:${RESET} $ver\n"
  git status -s | while IFS= read -r line; do
    local flag="${line:0:2}"
    case "$flag" in
      "M "|" M") echo -e "  ${YELLOW}~${RESET} ${line:3}" ;;
      "A "|" A") echo -e "  ${GREEN}+${RESET} ${line:3}" ;;
      "D "|" D") echo -e "  ${RED}-${RESET} ${line:3}" ;;
      "??")       echo -e "  ${CYAN}?${RESET} ${line:3}" ;;
      *)          echo "  $line" ;;
    esac
  done
  echo ""
}

cmd_log() {
  require_git
  local n="${1:-10}"
  echo ""
  git log --oneline -"$n" --color=always \
    --pretty=format:"%C(yellow)%h%Creset %C(cyan)%ad%Creset %s %C(dim)(%an)%Creset" \
    --date=short
  echo ""
}

cmd_version() {
  local part="${1:-patch}"
  local new_ver; new_ver=$(bump_version "$part")
  echo "$new_ver" > "$VERSION_FILE"
  ok "Version bumped → ${BOLD}$new_ver${RESET}"
}

cmd_update() {
  local self; self=$(command -v gt 2>/dev/null)
  [ -z "$self" ] && die "Cannot locate gt binary."

  info "Checking for updates..."

  local remote_ver
  if command -v curl &>/dev/null; then
    remote_ver=$(curl -fsSL "https://raw.githubusercontent.com/procloudify/gt/main/bin/gt" \
      | grep '^GT_VERSION=' | head -1 | cut -d'"' -f2)
  elif command -v wget &>/dev/null; then
    remote_ver=$(wget -qO- "https://raw.githubusercontent.com/procloudify/gt/main/bin/gt" \
      | grep '^GT_VERSION=' | head -1 | cut -d'"' -f2)
  else
    die "curl or wget is required to update."
  fi

  [ -z "$remote_ver" ] && die "Could not fetch remote version. Check your internet connection."

  if [ "$remote_ver" = "$GT_VERSION" ]; then
    ok "Already up to date — ${BOLD}v$GT_VERSION${RESET}"
    return 0
  fi

  info "Update available: ${BOLD}v$GT_VERSION${RESET} → ${BOLD}v$remote_ver${RESET}"

  if command -v curl &>/dev/null; then
    curl -fsSL "https://raw.githubusercontent.com/procloudify/gt/main/bin/gt" -o "$self"
  else
    wget -qO "$self" "https://raw.githubusercontent.com/procloudify/gt/main/bin/gt"
  fi
  chmod +x "$self"

  ok "Updated to ${BOLD}v$remote_ver${RESET}"
}

cmd_uninstall() {
  warn "This will remove gt from your system."
  printf "Are you sure? [y/N] "; read -r confirm
  case "$confirm" in
    y|Y|yes|YES) ;;
    *) info "Aborted."; exit 0 ;;
  esac

  local removed=0

  # ── Windows (Git Bash / WSL): remove ~/.gt/bin ──────────────────────────
  local win_install=""
  if [ -n "${USERPROFILE:-}" ]; then
    # Git Bash exposes USERPROFILE as a Windows path — convert to Unix path
    win_install=$(cygpath -u "$USERPROFILE" 2>/dev/null || echo "$USERPROFILE" | sed 's|\\|/|g' | sed 's|^\([A-Za-z]\):|/\L\1|')
    win_install="$win_install/.gt/bin"
  elif [ -n "${HOME:-}" ] && [ -d "$HOME/.gt/bin" ]; then
    win_install="$HOME/.gt/bin"
  fi

  if [ -n "$win_install" ] && [ -d "$win_install" ]; then
    rm -f "$win_install/gt" "$win_install/gt.cmd"
    ok "Removed gt from $win_install"
    removed=1
    # Remove parent ~/.gt if empty
    local gt_dir; gt_dir=$(dirname "$win_install")
    [ -d "$gt_dir" ] && [ -z "$(ls -A "$gt_dir")" ] && rmdir "$gt_dir"
    # Clean Windows user PATH via PowerShell
    if command -v powershell.exe &>/dev/null; then
      powershell.exe -NoProfile -Command "
        \$p = [Environment]::GetEnvironmentVariable('PATH','User') -split ';' | Where-Object { \$_ -notmatch '\\.gt\\\\bin' }
        [Environment]::SetEnvironmentVariable('PATH', (\$p -join ';'), 'User')
      " 2>/dev/null && ok "Removed from Windows PATH"
    fi
  fi

  # ── Mac / Linux: remove from ~/.local/bin or /usr/local/bin ────────────
  local self; self=$(command -v gt 2>/dev/null)
  if [ -n "$self" ] && [ -f "$self" ]; then
    local dir; dir=$(dirname "$self")
    rm -f "$self"
    ok "Removed gt from $dir"
    removed=1
    [ -d "$dir" ] && [ -z "$(ls -A "$dir")" ] && rmdir "$dir"
    # Clean shell rc PATH entries
    for rc in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.config/fish/config.fish"; do
      [ -f "$rc" ] && sed -i "/\.local\/bin/d" "$rc" 2>/dev/null || true
    done
    info "You may want to open a new terminal to apply PATH changes."
  fi

  [ "$removed" -eq 0 ] && die "gt not found. May already be uninstalled."
  ok "gt uninstalled."
}

cmd_init() {
  if git rev-parse --git-dir &>/dev/null; then
    warn "Already a git repo."
  else
    git init
    ok "Git repo initialized."
  fi
  ensure_version_file
  if [ ! -f ".gitignore" ]; then
    cat > .gitignore << 'IGNORE'
.DS_Store
node_modules/
*.log
IGNORE
    ok "Created .gitignore"
  fi
  ok "gt ready. Try: gt status"
}

cmd_help() {
  echo -e "
${BOLD}gt${RESET} — simple git flow CLI  v${GT_VERSION}  ${DIM}by Pro Cloudify${RESET}

${BOLD}USAGE${RESET}
  gt <command> [options]

${BOLD}COMMANDS${RESET}
  ${CYAN}push${RESET} [major|minor|patch] [-m \"msg\"]   bump version + commit + push main
  ${CYAN}dev${RESET}  [-m \"msg\"]                       commit + push to dev branch
  ${CYAN}branch${RESET} <name>                          create + push a new branch
  ${CYAN}switch${RESET} [name]                          switch branch (interactive if no name)
  ${CYAN}pull${RESET}  [branch]                         pull from branch (default: current)
  ${CYAN}merge${RESET} [branch]                         merge branch into current
  ${CYAN}status${RESET}                                 pretty status with version info
  ${CYAN}log${RESET}   [n]                              last n commits (default: 10)
  ${CYAN}version${RESET} [major|minor|patch]            bump .version file only
  ${CYAN}init${RESET}                                   init repo + .version + .gitignore
  ${CYAN}update${RESET}                                 update gt to the latest version
  ${CYAN}uninstall${RESET}                              remove gt from your system

${BOLD}EXAMPLES${RESET}
  gt push                          → 1.0.1  (auto patch bump)
  gt push -m \"fix login bug\"       → 1.0.1 — fix login bug
  gt push minor -m \"new dashboard\" → 1.1.0 — new dashboard
  gt push major                    → 2.0.0
  gt dev                           → dev snapshot
  gt dev -m \"working on auth\"      → working on auth
  gt branch feature/login
  gt switch main
  gt merge feature/login
  gt pull
  gt log 20

${DIM}  github.com/procloudify/gt${RESET}
"
}

# ── router ───────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    push)    cmd_push    "$@" ;;
    dev)     cmd_dev     "$@" ;;
    branch)  cmd_branch  "$@" ;;
    switch)  cmd_switch  "$@" ;;
    pull)    cmd_pull    "$@" ;;
    merge)   cmd_merge   "$@" ;;
    status)  cmd_status  "$@" ;;
    log)     cmd_log     "$@" ;;
    version) cmd_version "$@" ;;
    init)      cmd_init      "$@" ;;
    update)    cmd_update    "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
      local commands="push dev branch switch pull merge status log version init uninstall help"
      local best="" best_score=999
      for c in $commands; do
        local score=0
        local a="$cmd" b="$c"
        local len_a=${#a} len_b=${#b}
        local max=$(( len_a > len_b ? len_a : len_b ))
        for (( i=0; i<max; i++ )); do
          [ "${a:$i:1}" != "${b:$i:1}" ] && score=$(( score + 1 ))
        done
        score=$(( score + (len_a > len_b ? len_a - len_b : len_b - len_a) ))
        if (( score < best_score )); then
          best_score=$score
          best="$c"
        fi
      done
      if (( best_score <= 3 )); then
        echo -e "${RED}✗${RESET} Unknown command '${BOLD}$cmd${RESET}'. Did you mean: ${CYAN}gt $best${RESET}?" >&2
      else
        die "Unknown command '$cmd'. Run: gt help"
      fi
      exit 1
      ;;
  esac
}

main "$@"
